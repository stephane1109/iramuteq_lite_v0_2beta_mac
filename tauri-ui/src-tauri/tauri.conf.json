{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "IRaMuTeQ Lite",
  "version": "0.1.0",
  "identifier": "org.iramuteq.lite",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "IRaMuTeQ Lite",
        "width": 1100,
        "height": 800,
        "resizable": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    },
    "resources": {
      "../../backend/": "backend",
      "../../dictionnaires/": "dictionnaires",
      "../../help/": "help",
      "../../images/": "images",
      "../../iramuteqlite/": "iramuteqlite",
      "../../lda/": "lda"
    },
    "icon": [
      "icons/icon.png"
    ]
  }
}
